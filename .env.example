# Node Environment
NODE_ENV=development
PORT=3000

# Database Configuration
DB_TYPE=sqlite
# For SQLite
DB_STORAGE=./database.sqlite
# For SQL Server (uncomment and set the following if using mssql)
# DB_HOST=localhost
# DB_PORT=1433
# DB_NAME=getfitter
# DB_USER=sa
# DB_PASSWORD=YourStrong!Passw0rd

# JWT Configuration (to be used in Phase 3)
JWT_SECRET=your_jwt_secret_change_in_production
JWT_EXPIRES_IN=7d

# Bcrypt Configuration
BCRYPT_SALT_ROUNDS=12

# Static Assets Path
STATIC_PATH=./static